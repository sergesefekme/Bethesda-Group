# Form delivery — required for the contact, deck-request and careers forms to
# actually send. Set these in the AWS Amplify console under
# App settings → Environment variables, then redeploy.
#
# Until RESEND_API_KEY and CONTACT_FROM are both set, the forms do NOT report
# success: they show an error with a direct mailto link so enquiries are never
# silently lost.

# From https://resend.com/api-keys
RESEND_API_KEY=

# Must be a sender on a domain you have verified in Resend.
# e.g. website@bethesdaglobalnetwork.com
CONTACT_FROM=

# Optional. Where submissions are delivered.
# Defaults to the general address in lib/content/offices.ts.
CONTACT_TO=
